# Backend API URL (default: http://localhost:3001)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Cloudinary image upload (free tier)
# 1. Sign up at https://cloudinary.com (free)
# 2. In Dashboard > Settings > Upload > Upload presets, create an UNSIGNED preset
# 3. Copy your Cloud Name from the dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset_name_here

# Without Cloudinary, the image upload falls back to URL input — the app still works.
