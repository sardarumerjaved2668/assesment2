# Application
NODE_ENV=development
PORT=3001

# Database (MongoDB Atlas)
# Full SRV connection string. Include username, password and the "fullstack" database.
# Example: mongodb+srv://USERNAME:PASSWORD@cs.cc7em.mongodb.net/fullstack?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cs.cc7em.mongodb.net/fullstack?retryWrites=true&w=majority
DATABASE_NAME=fullstack

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000
