import {
  Entity,
  ObjectIdColumn,
  Column,
  CreateDateColumn,
  UpdateDateColumn,
} from 'typeorm';
import { ObjectId } from 'mongodb';

export enum OrderStatus {
  PENDING = 'pending',
  CONFIRMED = 'confirmed',
  SHIPPED = 'shipped',
  DELIVERED = 'delivered',
  CANCELLED = 'cancelled',
}

@Entity('orders')
export class Order {
  @ObjectIdColumn()
  id: ObjectId;

  // Reference to the owning user (stored as the user's id string).
  @Column()
  userId: string;

  @Column({ default: OrderStatus.PENDING })
  status: OrderStatus;

  @Column()
  totalAmount: number;

  @Column({ nullable: true })
  shippingAddress: string;

  // Order line items are embedded directly in the order document.
  @Column()
  items: any[];

  @CreateDateColumn()
  createdAt: Date;

  @UpdateDateColumn()
  updatedAt: Date;
}
