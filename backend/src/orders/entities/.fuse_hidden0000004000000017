import { Entity, ObjectIdColumn, Column } from 'typeorm';
import { ObjectId } from 'mongodb';

// Order line item. In MongoDB these are normally embedded inside the order
// document (see Order.items), but the entity is kept for typing/seed use.
@Entity('order_items')
export class OrderItem {
  @ObjectIdColumn()
  id: ObjectId;

  @Column()
  orderId: string;

  @Column()
  productId: string;

  @Column()
  quantity: number;

  @Column()
  unitPrice: number;

  @Column()
  subtotal: number;
}
